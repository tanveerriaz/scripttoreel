# ScriptToReel API keys — copy to api_keys.env and add your values:
#   cp config/api_keys.env.example config/api_keys.env
# Missing keys are fine; modules skip those sources.

# Pexels — https://www.pexels.com/api/
PEXELS_API_KEY=

# Pixabay — https://pixabay.com/api/docs/
PIXABAY_API_KEY=

# Unsplash — https://unsplash.com/developers
UNSPLASH_ACCESS_KEY=

# Freesound — https://freesound.org/apiv2/apply/
FREESOUND_API_KEY=

# LLM for Module 3 (script) — use OpenRouter OR Ollama, not both at once:
#   • OpenRouter: USE_OPENROUTER=true + OPENROUTER_API_KEY (no local Ollama)
#   • Ollama:     USE_OPENROUTER=false (default below) + ollama serve

# OpenRouter — https://openrouter.ai
USE_OPENROUTER=false
OPENROUTER_API_KEY=
OPENROUTER_MODEL=deepseek/deepseek-chat

# Ollama (local LLM) — used when USE_OPENROUTER is not true or key is missing
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2

# Optional defaults (used by some setups)
DEFAULT_RESOLUTION=1920x1080
DEFAULT_FPS=30
DEFAULT_DURATION=60
